# ===== Docker Compose Deployment =====
# Database
DB_ROOT_PASSWORD=your-root-password
DB_NAME=etl
DB_USER=etluser
DB_PASSWORD=your-db-password

# API
OPENAI_API_KEY=sk-your-openai-key
JWT_SECRET=your-jwt-secret

# UI port (default: 80)
UI_PORT=80

# ===== SSH Deployment (deploy.sh) =====
DEPLOY_HOST=user@example-host
DEPLOY_BACKEND_REMOTE_PATH=/srv/etl-banks-ar/api
DEPLOY_FRONTEND_REMOTE_PATH=/srv/etl-banks-ar/ui
DEPLOY_SERVICE_NAME=etl-banks-ar-api
DEPLOY_FRONTEND_URL=https://example-host
